---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs } from '../../utils/content';

const briefs = loadBriefs('zh');
const latest = briefs[0];
const groups = new Map<string, typeof briefs>();
for (const doc of briefs) {
  const month = String(doc.meta.date || '').slice(0, 7) || '未标日期';
  if (!groups.has(month)) groups.set(month, []);
  groups.get(month)?.push(doc);
}
---
<BaseLayout lang="zh" title="归档">
  <section class="archive-hero">
    <div>
      <h1 class="page-title">归档</h1>
      <p class="page-subtitle">按发布日期回看历史简报。页面只呈现已有内容，不改变生成顺序和论文选择。</p>
    </div>
    {latest && (
      <aside class="archive-highlight">
        <p class="section-kicker">最近一期</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
        <div class="article-meta">
          <span>{latest.meta.date}</span>
          <span>{latest.meta.candidate_count || 0} 候选</span>
          <a href={latest.url}>阅读</a>
        </div>
      </aside>
    )}
  </section>

  {[...groups.entries()].map(([month, docs]) => (
    <section class="month-group">
      <h2 class="month-title">{month}</h2>
      <div class="archive-grid">
        {docs.map((doc) => (
          <article class="article-card">
            <p class="section-kicker">{doc.meta.date}</p>
            <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
            {doc.meta.summary && <p>{doc.meta.summary}</p>}
            <div class="archive-meta-row">
              <span>{doc.meta.candidate_count || 0} 候选</span>
              <span>{doc.meta.featured_count || 0} 重点</span>
              <span>{doc.meta.mentions_count || 0} 关注</span>
              <span>源日 {doc.meta.actual_date || doc.meta.target_date || '-'}</span>
              {doc.meta.sources_page && <a class="issue-source-link" href={doc.meta.sources_page}>来源页</a>}
            </div>
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
