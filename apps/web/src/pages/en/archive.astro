---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs } from '../../utils/content';
const briefs = loadBriefs('en');
---
<BaseLayout lang="en" title="Archive">
  <h1>Archive</h1>
  <section class="article-list archive-list">
    {briefs.map((doc) => (
      <article class="article-card archive-card">
        <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
        <div class="issue-meta-row archive-meta-row">
          <span>{doc.meta.date}</span>
          <span>{doc.meta.candidate_count || 0} candidates</span>
          <span>{doc.meta.featured_count || 0} featured</span>
          <span>{doc.meta.mentions_count || 0} also tracked</span>
          {doc.meta.sources_page && <a class="issue-source-link" href={doc.meta.sources_page}>Source page</a>}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .archive-list { gap: 14px; }
  .archive-card h2 { margin-bottom: 12px; overflow-wrap: anywhere; }
  .archive-meta-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; color: var(--muted); font-size: 14px; }
  .archive-meta-row span { border: 1px solid var(--line); border-radius: 8px; background: var(--bg-soft); padding: 4px 10px; }
  .issue-source-link { font-weight: 700; text-decoration: none; }
</style>
