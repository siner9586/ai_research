---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadDocs, markdownToHtml } from '../../../utils/content';

export function getStaticPaths() {
  return loadDocs('zh').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const pageTitle = displayBriefTitle(doc.meta.title);
const isSources = doc.meta.page_type === 'sources';
const selectedCount = (doc.meta.featured_count || 0) + (doc.meta.mentions_count || 0);
const sourceDate = doc.meta.actual_date || doc.meta.target_date || doc.meta.date;
const body = doc.meta.page_type === 'brief'
  ? doc.body.replace(/\n\*\*日期\*\*:\s*\d{4}-\d{2}-\d{2}\n\n/, '\n')
  : doc.body;
---
<BaseLayout lang="zh" title={pageTitle} description={doc.meta.summary}>
  <article class="prose">
    <div class="article-meta issue-meta-line">
      <span>{doc.meta.date}</span>
      <span>{isSources ? '来源页' : '每日简报'}</span>
      <span>{doc.meta.candidate_count || 0} 篇候选</span>
      <span>{doc.meta.featured_count || 0} 篇重点</span>
      <span>{doc.meta.mentions_count || 0} 篇补充</span>
      {isSources && doc.meta.brief_page && <a class="paper-meta-link" href={doc.meta.brief_page}>返回简报</a>}
      {!isSources && doc.meta.sources_page && <a class="paper-meta-link" href={doc.meta.sources_page}>来源页</a>}
    </div>
    {!isSources && (
      <p class="candidate-note">
        本期从 <strong>{sourceDate}</strong> 论文源抓取并去重 <strong>{doc.meta.candidate_count || 0}</strong> 篇候选论文，筛选 <strong>{doc.meta.featured_count || 0}</strong> 篇重点论文与 <strong>{doc.meta.mentions_count || 0}</strong> 篇补充关注。
      </p>
    )}
    <Fragment set:html={markdownToHtml(body)} />
  </article>
</BaseLayout>

<style>
  .issue-meta-line { display: flex; flex-wrap: wrap; gap: 8px 12px; align-items: center; }
  .candidate-note { margin: 14px 0 22px; padding: 10px 12px; border: 1px solid var(--border); border-radius: 14px; background: var(--surface-soft); color: var(--muted); font-size: 0.94rem; }
  .candidate-note strong { color: var(--text); }
</style>
