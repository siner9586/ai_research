---
import '../styles/global.css';
import { loadSite } from '../utils/content';

const { lang = 'en', title, description } = Astro.props;
const site = loadSite()[lang];
const otherLang = lang === 'zh' ? 'en' : 'zh';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | ${site.name}` : site.name}</title>
    <meta name="description" content={description || site.tagline} />
    <link rel="alternate" type="application/rss+xml" href={`/${lang}/feed.xml`} />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={`/${lang}/`}>{site.name}</a>
        <div class="nav-links">
          <a href={`/${lang}/archive/`}>{lang === 'zh' ? '归档' : 'Archive'}</a>
          <a href={`/${lang}/topics/`}>{lang === 'zh' ? '专题' : 'Topics'}</a>
          <a href={`/${lang}/search/`}>{lang === 'zh' ? '搜索' : 'Search'}</a>
          <a href={`/${lang}/methodology/`}>{lang === 'zh' ? '方法' : 'Method'}</a>
          <a href={`/${lang}/feed.xml`}>RSS</a>
          <a href={`/${otherLang}/`}>{otherLang.toUpperCase()}</a>
        </div>
      </nav>
    </header>
    <main class="page">
      <slot />
    </main>
    <footer class="footer">
      <span>{site.tagline}</span>
      <span>{lang === 'zh' ? '内容由本仓库流水线生成，原论文链接为事实来源。' : 'Generated by the local pipeline; original papers remain the source of record.'}</span>
    </footer>
  </body>
</html>
