---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs, loadSite, loadTopics, topicCounts } from '../../utils/content';
import { getFeaturedPaperTitleItems } from '../../utils/featuredTitles';

const lang = 'en';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(1, 7);
const latestTopics = latest?.meta.tags?.slice(0, 7) || [];
const latestFeaturedTitles = getFeaturedPaperTitleItems(latest, 'en', 6);
const counts = topicCounts(lang);
const topics = loadTopics().filter((topic) => counts[topic.slug] > 0).slice(0, 9);
const isFallback = latest && latest.meta.actual_date && latest.meta.target_date && latest.meta.actual_date !== latest.meta.target_date;
const topicNames: Record<string, string> = {
  agents: 'Agents',
  reasoning: 'Reasoning',
  training: 'Training',
  rag: 'RAG',
  multimodal: 'Multimodal',
  code: 'Code AI',
  'vision-generation': 'Image generation',
  'video-generation': 'Video generation',
  safety: 'Safety',
  'speech-audio': 'Speech/audio',
  robotics: 'Robotics',
  interpretability: 'Interpretability',
  evaluation: 'Evaluation',
  'data-engineering': 'Data',
  systems: 'Systems',
};
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="home-hero">
    <div class="hero-copy">
      <p class="eyebrow">AI Research Brief</p>
      <h1>AI Research Brief</h1>
      <p class="hero-subtitle">Source-first daily briefs for AI papers worth tracking.</p>
      <p class="hero-note">Daily updates · Bilingual notes · Traceable sources</p>
      <div class="action-row">
        <a class="button" href={latest?.url || '/en/archive/'}>Read latest brief</a>
        <a class="button secondary" href="/en/archive/">Archive</a>
        <a class="button secondary" href="/zh/">中文</a>
      </div>
    </div>

    <aside class="hero-panel" aria-label="Latest issue metrics">
      <p class="hero-panel-title">Latest issue</p>
      <div class="metrics">
        <div class="metric">
          <span>Published</span>
          <strong>{latest?.meta.date || '-'}</strong>
        </div>
        <div class="metric">
          <span>Actual source</span>
          <strong>{latest?.meta.actual_date || latest?.meta.target_date || '-'}</strong>
        </div>
        <div class="metric">
          <span>Candidates</span>
          <strong>{latest?.meta.candidate_count || 0}</strong>
        </div>
        <div class="metric">
          <span>Featured / tracked</span>
          <strong>{latest ? `${latest.meta.featured_count || 0}/${latest.meta.mentions_count || 0}` : '-'}</strong>
        </div>
      </div>
      {isFallback && <p class="fallback-badge">Source date fallback</p>}
    </aside>
  </section>

  {latest ? (
    <section class="latest-panel">
      <div>
        <p class="section-kicker">Latest issue · {latest.meta.date}</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
        {latest.meta.summary && <p class="latest-summary">{latest.meta.summary}</p>}
        <div class="issue-meta-row">
          <span>Target {latest.meta.target_date || '-'}</span>
          <span>Actual {latest.meta.actual_date || '-'}</span>
          <span>{latest.meta.candidate_count || 0} candidates</span>
          <span>{latest.meta.featured_count || 0} featured</span>
          <span>{latest.meta.mentions_count || 0} tracked</span>
          {isFallback && <span class="fallback-badge">Source date fallback</span>}
        </div>
        {latestFeaturedTitles.length > 0 && (
          <div class="featured-paper-strip" aria-label="Featured">
            <p class="featured-paper-kicker">Featured</p>
            <ol class="featured-paper-title-list">
              {latestFeaturedTitles.map((item, index: number) => (
                <li>
                  <span class="featured-paper-number">{index + 1}</span>
                  <span class="featured-paper-title-text">{item.title}{item.url && <a class="featured-paper-link" href={item.url} aria-label={`Open source paper: ${item.title}`} target="_blank" rel="noopener noreferrer">↗</a>}</span>
                </li>
              ))}
            </ol>
          </div>
        )}
        <div class="action-row">
          <a class="button" href={latest.url}>English brief</a>
          <a class="button secondary" href={`/zh/daily/${latest.slug}/`}>中文简报</a>
          {latest.meta.sources_page && <a class="button secondary" href={latest.meta.sources_page}>Source page</a>}
        </div>
      </div>
      <aside class="latest-side">
        <div class="topic-chips" aria-label="Issue topics">
          {latestTopics.map((topic: string) => <a href={`/en/topics/${topic}/`}>{topicNames[topic] || topic}</a>)}
        </div>
      </aside>
    </section>
  ) : (
    <p class="muted">No generated content yet.</p>
  )}

  <section>
    <div class="section-head">
      <div>
        <h2>Recent Issues</h2>
        <p>Publication order follows the generated brief order.</p>
      </div>
      <a href="/en/archive/">Full archive</a>
    </div>
    <div class="recent-grid">
      {recent.map((doc) => (
        <article class="article-card">
          <p class="section-kicker">{doc.meta.date}</p>
          <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
          {doc.meta.summary && <p>{doc.meta.summary}</p>}
          <div class="article-meta">
            <span>{doc.meta.candidate_count || 0} candidates</span>
            <span>Source {doc.meta.actual_date || doc.meta.target_date || '-'}</span>
            <a href={doc.url}>Read</a>
            <a href={`/zh/daily/${doc.slug}/`}>ZH</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <h2>Topics</h2>
        <p>Built from existing tags/topics only.</p>
      </div>
      <a href="/en/topics/">View all</a>
    </div>
    <div class="topic-grid">
      {topics.map((topic) => (
        <a class="topic-row" href={`/en/topics/${topic.slug}/`}>
          <strong>{topic.en}</strong>
          <p>{counts[topic.slug]} related briefs</p>
        </a>
      ))}
    </div>
  </section>

  <section class="info-card">
    <h2>Reading Boundary</h2>
    <p>This project generates briefs from public arXiv metadata and public signals for research tracking and discovery. Original papers remain the source of record.</p>
  </section>
</BaseLayout>
