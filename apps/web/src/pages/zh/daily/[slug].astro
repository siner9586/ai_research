---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { loadDocs, markdownToHtml } from '../../../utils/content';

export function getStaticPaths() {
  return loadDocs('zh').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
---
<BaseLayout lang="zh" title={doc.meta.title} description={doc.meta.summary}>
  <article class="prose">
    <div class="article-meta">
      <span>{doc.meta.date}</span>
      <span>{doc.meta.page_type === 'sources' ? '来源页' : '每日简报'}</span>
      {doc.meta.brief_page && <a href={doc.meta.brief_page}>返回简报</a>}
      {doc.meta.sources_page && <a href={doc.meta.sources_page}>来源与评分</a>}
    </div>
    <Fragment set:html={markdownToHtml(doc.body)} />
  </article>
</BaseLayout>
