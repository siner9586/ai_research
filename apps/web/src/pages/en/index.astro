---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs, loadSite } from '../../utils/content';

const lang = 'en';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(0, 7);
const latestTopics = latest?.meta.tags?.slice(0, 6) || [];
const topicNames: Record<string, string> = {
  agents: 'Agents',
  reasoning: 'Reasoning',
  training: 'Training',
  rag: 'RAG',
  multimodal: 'Multimodal',
  code: 'Code AI',
  'vision-generation': 'Image generation',
  'video-generation': 'Video generation',
  safety: 'Safety',
  'speech-audio': 'Speech/audio',
  robotics: 'Robotics',
  interpretability: 'Interpretability',
  evaluation: 'Evaluation',
  'data-engineering': 'Data',
  systems: 'Systems',
};
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="home-hero compact-home">
    <div class="hero-copy">
      <h1>Find the AI papers worth tracking before the pile becomes unreadable.</h1>
      <p class="hero-subtitle">A compact daily brief for agents, reasoning, training optimization, RAG, multimodal systems, code intelligence, generation, safety, speech, robotics, evaluation, data engineering, and systems deployment.</p>
      <div class="action-row">
        <a class="button" href={latest?.url || '/en/archive/'}>Read latest brief</a>
        <a class="button secondary" href="/en/search/">Search papers</a>
        <a class="button secondary" href="/en/methodology/">View method</a>
      </div>
    </div>
  </section>

  {latest && (
    <section class="latest-panel with-topics">
      <div class="latest-main">
        <p class="section-kicker">Latest issue · {latest.meta.date}</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
      </div>
      <aside class="topic-chips" aria-label="Issue topics">
        {latestTopics.map((topic: string) => <span>{topicNames[topic] || topic}</span>)}
      </aside>
    </section>
  )}

  <section class="quick-nav">
    <a href="/en/archive/">Full archive</a>
    <a href="/en/topics/">Topic index</a>
    <a href="/en/feed.xml">RSS feed</a>
    <a href="/en/privacy/">Privacy</a>
  </section>

  <section class="article-list refined-list">
    <div class="section-head clean">
      <h2>Recent updates</h2>
      <a href="/en/archive/">View all</a>
    </div>
    {briefs.length === 0 && <p>No generated content yet. Run <code>ai-brief mock-run</code> to create a daily brief.</p>}
    {recent.map((doc) => (
      <article class="article-card elevated-card">
        <p class="section-kicker">{doc.meta.date}</p>
        <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
      </article>
    ))}
  </section>
</BaseLayout>
