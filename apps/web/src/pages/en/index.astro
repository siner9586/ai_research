---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs, loadSite } from '../../utils/content';
import { getFeaturedPaperTitleItems } from '../../utils/featuredTitles';

const lang = 'en';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(0, 7);
const latestTopics = latest?.meta.tags?.slice(0, 6) || [];
const latestFeaturedTitles = getFeaturedPaperTitleItems(latest, 'en', 6);
const topicNames: Record<string, string> = {
  agents: 'Agents',
  reasoning: 'Reasoning',
  training: 'Training',
  rag: 'RAG',
  multimodal: 'Multimodal',
  code: 'Code AI',
  'vision-generation': 'Image generation',
  'video-generation': 'Video generation',
  safety: 'Model governance',
  'speech-audio': 'Speech/audio',
  robotics: 'Robotics',
  interpretability: 'Interpretability',
  evaluation: 'Evaluation',
  'data-engineering': 'Data',
  systems: 'Systems',
};
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="home-hero compact-home">
    <div class="hero-copy">
      <h1>Find the AI papers worth tracking before the pile becomes unreadable.</h1>
      <p class="hero-subtitle">A compact daily brief built from arXiv collection, rule-based ranking, and scheduled GitHub Actions automation.</p>
      <div class="action-row">
        <a class="button" href={latest?.url || '/en/archive/'}>Read latest brief</a>
        <a class="button secondary" href="/en/search/">Search papers</a>
        <a class="button secondary" href="/zh/">中文</a>
      </div>
    </div>
  </section>

  {latest && (
    <section class="latest-panel with-topics latest-stack">
      <div class="latest-main">
        <p class="section-kicker">Latest issue · {latest.meta.date} · {latest.meta.candidate_count || 0} candidates</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
        {latestFeaturedTitles.length > 0 && (
          <div class="featured-paper-strip" aria-label="Featured">
            <p class="featured-paper-kicker">Featured</p>
            <ol class="featured-paper-title-list">
              {latestFeaturedTitles.map((item, index: number) => (
                <li>
                  <span class="featured-paper-number">{index + 1}</span>
                  <span class="featured-paper-title-text">{item.title}{item.url && <a class="featured-paper-link" href={item.url} aria-label={`Open source paper: ${item.title}`} target="_blank" rel="noopener noreferrer">🔗</a>}</span>
                </li>
              ))}
            </ol>
          </div>
        )}
        <div class="issue-meta-row">
          <span>{latest.meta.featured_count || 0} featured</span>
          <span>{latest.meta.mentions_count || 0} additional</span>
          {latest.meta.sources_page && <a class="issue-source-link" href={latest.meta.sources_page}>Source page</a>}
        </div>
      </div>
      <aside class="topic-chips issue-keyword-row" aria-label="Issue topics">
        {latestTopics.map((topic: string) => <span>{topicNames[topic] || topic}</span>)}
      </aside>
    </section>
  )}

  <section class="quick-nav">
    <a href="/en/archive/">Full archive</a>
    <a href="/en/topics/">Topic index</a>
    <a href="/en/feed.xml">RSS feed</a>
    <a href="/en/privacy/">Privacy</a>
  </section>

  <section class="article-list refined-list">
    <div class="section-head clean">
      <h2>Recent updates</h2>
      <a href="/en/archive/">View all</a>
    </div>
    {briefs.length === 0 && <p>No generated content yet.</p>}
    {recent.map((doc) => (
      <article class="article-card elevated-card">
        <p class="section-kicker">{doc.meta.date}</p>
        <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .home-hero h1 { font-size: clamp(20px, 3vw, 32px); line-height: 1.14; letter-spacing: -0.035em; }
  .hero-subtitle { font-size: clamp(14px, 1.35vw, 16px); line-height: 1.58; max-width: 760px; }
  .action-row .button { font-size: 14px; padding: 9px 13px; border-radius: 999px; }
  .latest-stack { grid-template-columns: minmax(0, 1fr); align-items: flex-start; gap: 14px; }
  .latest-main { min-width: 0; }
  .latest-panel h2 { margin-bottom: 12px; font-size: clamp(19px, 2.8vw, 27px); line-height: 1.24; overflow-wrap: anywhere; }
  .featured-paper-strip { margin: 12px 0 14px; padding: 12px 14px; border: 1px solid var(--border); border-radius: 16px; background: var(--surface-soft); }
  .featured-paper-kicker { margin: 0 0 8px; color: var(--muted); font-size: 13px; font-weight: 800; letter-spacing: 0.02em; }
  .featured-paper-title-list { display: grid; gap: 6px; margin: 0; padding: 0; list-style: none; }
  .featured-paper-title-list li { display: grid; grid-template-columns: 24px minmax(0, 1fr); gap: 8px; align-items: start; color: var(--text); font-size: clamp(13px, 1.35vw, 15px); line-height: 1.45; }
  .featured-paper-number { display: inline-grid; place-items: center; width: 20px; height: 20px; border-radius: 999px; background: var(--surface); color: var(--muted); font-size: 12px; font-weight: 800; }
  .featured-paper-title-text { min-width: 0; }
  .featured-paper-link { display: inline; margin-left: 0; color: var(--accent); text-decoration: none; font-weight: 400; line-height: 1; }
  .featured-paper-link:hover { text-decoration: underline; background: transparent; }
  .issue-meta-row, .issue-keyword-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; justify-content: flex-start; }
  .issue-meta-row { color: var(--muted); font-size: 14px; }
  .issue-keyword-row { font-size: 15px; }
  .issue-source-link { font-weight: 700; text-decoration: none; }
  .quick-nav a, .section-head h2, .section-head a, .article-card .section-kicker, .article-card h2, .article-list p { font-size: calc(1em - 1px); }
  @media (max-width: 820px) {
    .home-hero h1 { font-size: clamp(20px, 6vw, 29px); line-height: 1.16; }
    .hero-subtitle { font-size: 14px; }
    .action-row .button { font-size: 13px; padding: 8px 11px; }
    .featured-paper-title-list li { grid-template-columns: 22px minmax(0, 1fr); font-size: 13px; }
  }
</style>
