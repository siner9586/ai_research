---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs, loadSite } from '../../utils/content';

const lang = 'en';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(0, 7);
const latestTopics = latest?.meta.tags?.slice(0, 6) || [];
const topicNames: Record<string, string> = {
  agents: 'Agents',
  reasoning: 'Reasoning',
  training: 'Training',
  rag: 'RAG',
  multimodal: 'Multimodal',
  code: 'Code AI',
  'vision-generation': 'Image generation',
  'video-generation': 'Video generation',
  safety: 'Model governance',
  'speech-audio': 'Speech/audio',
  robotics: 'Robotics',
  interpretability: 'Interpretability',
  evaluation: 'Evaluation',
  'data-engineering': 'Data',
  systems: 'Systems',
};
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="home-hero compact-home">
    <div class="hero-copy">
      <h1>Find the AI papers worth tracking before the pile becomes unreadable.</h1>
      <p class="hero-subtitle">A compact daily brief built from arXiv collection, rule-based ranking, and scheduled GitHub Actions automation.</p>
      <div class="action-row">
        <a class="button" href={latest?.url || '/en/archive/'}>Read latest brief</a>
        <a class="button secondary" href="/en/search/">Search papers</a>
        <a class="button secondary" href="/zh/">中文</a>
      </div>
    </div>
  </section>

  {latest && (
    <section class="latest-panel with-topics latest-stack">
      <div class="latest-main">
        <p class="section-kicker">Latest issue · {latest.meta.date} · {latest.meta.candidate_count || 0} candidates</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
        <div class="issue-meta-row">
          <span>{latest.meta.featured_count || 0} featured</span>
          <span>{latest.meta.mentions_count || 0} additional</span>
          {latest.meta.sources_page && <a class="issue-source-link" href={latest.meta.sources_page}>Source page</a>}
        </div>
      </div>
      <aside class="topic-chips issue-keyword-row" aria-label="Issue topics">
        {latestTopics.map((topic: string) => <span>{topicNames[topic] || topic}</span>)}
      </aside>
    </section>
  )}

  <section class="quick-nav">
    <a href="/en/archive/">Full archive</a>
    <a href="/en/topics/">Topic index</a>
    <a href="/en/feed.xml">RSS feed</a>
    <a href="/en/privacy/">Privacy</a>
  </section>

  <section class="article-list refined-list">
    <div class="section-head clean">
      <h2>Recent updates</h2>
      <a href="/en/archive/">View all</a>
    </div>
    {briefs.length === 0 && <p>No generated content yet.</p>}
    {recent.map((doc) => (
      <article class="article-card elevated-card">
        <p class="section-kicker">{doc.meta.date}</p>
        <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .home-hero h1 { font-size: clamp(24px, 4vw, 46px); line-height: 1.08; letter-spacing: -0.045em; }
  .hero-subtitle { font-size: clamp(17px, 1.7vw, 20px); }
  .latest-stack { grid-template-columns: minmax(0, 1fr); align-items: flex-start; gap: 14px; }
  .latest-main { min-width: 0; }
  .latest-panel h2 { margin-bottom: 12px; font-size: clamp(21px, 3.3vw, 31px); overflow-wrap: anywhere; }
  .issue-meta-row, .issue-keyword-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; justify-content: flex-start; }
  .issue-meta-row { color: var(--muted); font-size: 13px; }
  .issue-keyword-row { font-size: 15px; }
  .issue-source-link { font-weight: 700; text-decoration: none; }
  .action-row .button, .quick-nav a, .section-head h2, .section-head a, .article-card .section-kicker, .article-card h2, .article-list p { font-size: calc(1em - 1px); }
  @media (max-width: 820px) { .home-hero h1 { font-size: clamp(22px, 7vw, 32px); line-height: 1.12; } }
</style>
