---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { loadDocs, markdownToHtml } from '../../../utils/content';

export function getStaticPaths() {
  return loadDocs('en').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
---
<BaseLayout lang="en" title={doc.meta.title} description={doc.meta.summary}>
  <article class="prose">
    <div class="article-meta">
      <span>{doc.meta.date}</span>
      <span>{doc.meta.page_type === 'sources' ? 'source log' : 'daily brief'}</span>
      {doc.meta.brief_page && <a href={doc.meta.brief_page}>brief</a>}
      {doc.meta.sources_page && <a href={doc.meta.sources_page}>sources and scoring</a>}
    </div>
    <Fragment set:html={markdownToHtml(doc.body)} />
  </article>
</BaseLayout>
