---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadBriefs, loadSite } from '../../utils/content';

const lang = 'zh';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(0, 7);
const totalCandidates = briefs.reduce((sum, doc) => sum + Number(doc.meta.candidate_count || 0), 0);
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="hero">
    <div>
      <h1>{site.name}</h1>
      <p>{site.tagline}</p>
      <div class="action-row">
        <a class="button" href="/zh/feed.xml">RSS</a>
        <a class="button secondary" href="/zh/methodology/">方法论</a>
        <a class="button secondary" href="/zh/search/">搜索</a>
      </div>
    </div>
    <div class="metrics">
      <div class="metric"><strong>{briefs.length}</strong><span>期简报</span></div>
      <div class="metric"><strong>{totalCandidates}</strong><span>篇候选</span></div>
      <div class="metric"><strong>15</strong><span>个专题</span></div>
    </div>
  </section>
  {latest && (
    <section class="latest-issue">
      <p class="section-kicker">最新一期</p>
      <h2><a href={latest.url}>{latest.meta.title}</a></h2>
      <div class="article-meta">
        <span>{latest.meta.date}</span>
        <span>候选 {latest.meta.candidate_count} 篇</span>
        <span>重点 {latest.meta.featured_count} 篇</span>
        <a href={latest.meta.sources_page}>来源与评分</a>
      </div>
      <p>{latest.meta.summary}</p>
    </section>
  )}
  <section class="subscribe-strip">
    <span>订阅</span>
    <a href="/zh/feed.xml">中文 RSS</a>
    <a href="/en/feed.xml">English RSS</a>
    <a href="/zh/privacy/">隐私</a>
  </section>
  <section class="article-list">
    {briefs.length === 0 && <p>还没有生成内容。运行 <code>ai-brief mock-run</code> 后会出现每日简报。</p>}
    {recent.map((doc) => (
      <article class="article-card">
        <h2><a href={doc.url}>{doc.meta.title}</a></h2>
        <div class="article-meta">
          <span>{doc.meta.date}</span>
          <span>候选 {doc.meta.candidate_count} 篇</span>
          <span>重点 {doc.meta.featured_count} 篇</span>
          <a href={doc.meta.sources_page}>来源与评分</a>
        </div>
        <p>{doc.meta.summary}</p>
      </article>
    ))}
  </section>
</BaseLayout>
