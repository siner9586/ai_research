---
import BaseLayout from '../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs, loadSite, loadTopics, topicCounts } from '../utils/content';
import { getFeaturedPaperTitleItems } from '../utils/featuredTitles';

const lang = 'zh';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(1, 7);
const latestTopics = latest?.meta.tags?.slice(0, 7) || [];
const latestFeaturedTitles = getFeaturedPaperTitleItems(latest, 'zh', 6);
const counts = topicCounts(lang);
const topics = loadTopics().filter((topic) => counts[topic.slug] > 0).slice(0, 9);
const isFallback = latest && latest.meta.actual_date && latest.meta.target_date && latest.meta.actual_date !== latest.meta.target_date;
const topicNames: Record<string, string> = {
  agents: 'Agent',
  reasoning: '推理',
  training: '训练优化',
  rag: 'RAG',
  multimodal: '多模态',
  code: '代码智能',
  'vision-generation': '图像生成',
  'video-generation': '视频生成',
  safety: '安全',
  'speech-audio': '语音/音频',
  robotics: '机器人',
  interpretability: '可解释性',
  evaluation: '评测',
  'data-engineering': '数据工程',
  systems: '系统部署',
};
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="home-hero">
    <div class="hero-copy">
      <p class="eyebrow">AI Research Brief</p>
      <h1>AI 研究简报</h1>
      <p class="hero-subtitle">从 arXiv 与公开信号中筛出值得跟进的 AI 论文。</p>
      <p class="hero-note">每日自动更新 · 中英双语 · 来源可追溯</p>
      <div class="action-row">
        <a class="button" href={latest?.url || '/zh/archive/'}>阅读最新简报</a>
        <a class="button secondary" href="/zh/archive/">查看归档</a>
        <a class="button secondary" href="/en/">English</a>
      </div>
    </div>

    <aside class="hero-panel" aria-label="最新一期数据">
      <p class="hero-panel-title">最新一期</p>
      <div class="metrics">
        <div class="metric">
          <span>发布日期</span>
          <strong>{latest?.meta.date || '-'}</strong>
        </div>
        <div class="metric">
          <span>实际源日</span>
          <strong>{latest?.meta.actual_date || latest?.meta.target_date || '-'}</strong>
        </div>
        <div class="metric">
          <span>候选论文</span>
          <strong>{latest?.meta.candidate_count || 0}</strong>
        </div>
        <div class="metric">
          <span>重点 / 关注</span>
          <strong>{latest ? `${latest.meta.featured_count || 0}/${latest.meta.mentions_count || 0}` : '-'}</strong>
        </div>
      </div>
      {isFallback && <p class="fallback-badge">源日回退</p>}
    </aside>
  </section>

  {latest ? (
    <section class="latest-panel">
      <div>
        <p class="section-kicker">最新一期 · {latest.meta.date}</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
        {latest.meta.summary && <p class="latest-summary">{latest.meta.summary}</p>}
        <div class="issue-meta-row">
          <span>目标源日 {latest.meta.target_date || '-'}</span>
          <span>实际源日 {latest.meta.actual_date || '-'}</span>
          <span>{latest.meta.candidate_count || 0} 篇候选</span>
          <span>{latest.meta.featured_count || 0} 篇重点</span>
          <span>{latest.meta.mentions_count || 0} 篇关注</span>
          {isFallback && <span class="fallback-badge">源日回退</span>}
        </div>
        {latestFeaturedTitles.length > 0 && (
          <div class="featured-paper-strip" aria-label="本期重点">
            <p class="featured-paper-kicker">本期重点</p>
            <ol class="featured-paper-title-list">
              {latestFeaturedTitles.map((item, index: number) => (
                <li>
                  <span class="featured-paper-number">{index + 1}</span>
                  <span class="featured-paper-title-text">{item.title}{item.url && <a class="featured-paper-link" href={item.url} aria-label={`打开原论文：${item.title}`} target="_blank" rel="noopener noreferrer">↗</a>}</span>
                </li>
              ))}
            </ol>
          </div>
        )}
        <div class="action-row">
          <a class="button" href={latest.url}>中文简报</a>
          <a class="button secondary" href={`/en/daily/${latest.slug}/`}>English brief</a>
          {latest.meta.sources_page && <a class="button secondary" href={latest.meta.sources_page}>来源页</a>}
        </div>
      </div>
      <aside class="latest-side">
        <div class="topic-chips" aria-label="本期主题">
          {latestTopics.map((topic: string) => <a href={`/zh/topics/${topic}/`}>{topicNames[topic] || topic}</a>)}
        </div>
      </aside>
    </section>
  ) : (
    <p class="muted">还没有生成简报。</p>
  )}

  <section>
    <div class="section-head">
      <div>
        <h2>最近几期</h2>
        <p>按发布日期倒序展示，不改变自动生成顺序。</p>
      </div>
      <a href="/zh/archive/">全部归档</a>
    </div>
    <div class="recent-grid">
      {recent.map((doc) => (
        <article class="article-card">
          <p class="section-kicker">{doc.meta.date}</p>
          <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
          {doc.meta.summary && <p>{doc.meta.summary}</p>}
          <div class="article-meta">
            <span>{doc.meta.candidate_count || 0} 候选</span>
            <span>源日 {doc.meta.actual_date || doc.meta.target_date || '-'}</span>
            <a href={doc.url}>阅读</a>
            <a href={`/en/daily/${doc.slug}/`}>EN</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <h2>主题入口</h2>
        <p>来自已有 tags/topics，不新增分类逻辑。</p>
      </div>
      <a href="/zh/topics/">查看全部</a>
    </div>
    <div class="topic-grid">
      {topics.map((topic) => (
        <a class="topic-row" href={`/zh/topics/${topic.slug}/`}>
          <strong>{topic.zh}</strong>
          <p>{counts[topic.slug]} 期相关简报</p>
        </a>
      ))}
    </div>
  </section>

  <section class="info-card">
    <h2>阅读边界</h2>
    <p>本项目基于 arXiv 公开元数据与公开信号自动生成，用于研究跟踪与信息筛选；重点论文仍应以原文为准。</p>
  </section>
</BaseLayout>
