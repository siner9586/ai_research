---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadDocs, markdownToHtml } from '../../../utils/content';
import { getFeaturedPaperTitleItems, renderFeaturedPaperTitlesHtml } from '../../../utils/featuredTitles';

export function getStaticPaths() {
  return loadDocs('en').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const pageTitle = displayBriefTitle(doc.meta.title);
const isSources = doc.meta.page_type === 'sources';
const sourceDate = doc.meta.actual_date || doc.meta.target_date || doc.meta.date;
const isFallback = Boolean(doc.meta.actual_date && doc.meta.target_date && doc.meta.actual_date !== doc.meta.target_date);
const body = doc.meta.page_type === 'brief'
  ? doc.body.replace(/\n\*\*Date\*\*:\s*\d{4}-\d{2}-\d{2}\n\n/, '\n')
  : doc.body;
const displayBody = body.replace(/^\s*#\s+.*\n+/, '');
const featuredTitles = !isSources ? getFeaturedPaperTitleItems(doc, 'en', 6) : [];
const articleHtml = markdownToHtml(displayBody);
const featuredDigestHtml = !isSources && featuredTitles.length > 0
  ? renderFeaturedPaperTitlesHtml(featuredTitles, 'en')
  : '';
---
<BaseLayout lang="en" title={pageTitle} description={doc.meta.summary}>
  <article class:list={['brief-article', isSources && 'source-article']}>
    <header class="brief-hero">
      <span class="date-badge">{doc.meta.date}</span>
      <h1>{pageTitle}</h1>
      {doc.meta.summary && <p class="brief-summary">{doc.meta.summary}</p>}
      <div class="brief-actions">
        {isSources && doc.meta.brief_page && <a class="button" href={doc.meta.brief_page}>Back to brief</a>}
        {!isSources && doc.meta.sources_page && <a class="button secondary" href={doc.meta.sources_page}>View sources</a>}
        <a class="button secondary" href={`/zh/daily/${doc.slug}/`}>中文</a>
      </div>
    </header>

    <div class="brief-meta-bar" aria-label="Issue metadata">
      <span>Published <strong>{doc.meta.date}</strong></span>
      <span>Target source <strong>{doc.meta.target_date || '-'}</strong></span>
      <span>Actual source <strong>{doc.meta.actual_date || sourceDate}</strong></span>
      <span>Candidates <strong>{doc.meta.candidate_count || 0}</strong></span>
      <span>Featured <strong>{doc.meta.featured_count || 0}</strong></span>
      <span>Tracked <strong>{doc.meta.mentions_count || 0}</strong></span>
      {isFallback && <span class="fallback-badge">Source date fallback</span>}
    </div>

    {isSources ? (
      <section class="source-info-card">
        <h2>Generation Record</h2>
        <p>This page preserves selected papers, candidate scale, and source-date metadata for traceability. The page only changes presentation, not selected papers, ordering, or counts.</p>
      </section>
    ) : (
      <Fragment>
        <p class="source-info-card">
          This issue fetched and deduplicated <strong>{doc.meta.candidate_count || 0}</strong> candidate papers from the <strong>{sourceDate}</strong> source date, then selected <strong>{doc.meta.featured_count || 0}</strong> featured papers and <strong>{doc.meta.mentions_count || 0}</strong> additional mentions.
        </p>
        {featuredDigestHtml && <Fragment set:html={featuredDigestHtml} />}
      </Fragment>
    )}

    <div class="prose">
      <Fragment set:html={articleHtml} />
    </div>
  </article>
</BaseLayout>
