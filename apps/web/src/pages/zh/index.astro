---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs, loadSite } from '../../utils/content';

const lang = 'zh';
const site = loadSite()[lang];
const briefs = loadBriefs(lang);
const latest = briefs[0];
const recent = briefs.slice(0, 7);
const latestTopics = latest?.meta.tags?.slice(0, 6) || [];
const topicNames: Record<string, string> = {
  agents: 'Agent',
  reasoning: '推理',
  training: '训练优化',
  rag: 'RAG',
  multimodal: '多模态',
  code: '代码智能',
  'vision-generation': '图像生成',
  'video-generation': '视频生成',
  safety: '安全对齐',
  'speech-audio': '语音音频',
  robotics: '机器人',
  interpretability: '可解释性',
  evaluation: '评测',
  'data-engineering': '数据工程',
  systems: '系统部署',
};
---
<BaseLayout lang={lang} title={site.name} description={site.tagline}>
  <section class="home-hero compact-home">
    <div class="hero-copy">
      <h1>每天从 AI 论文里，筛出值得跟进的研究线索。</h1>
      <p class="hero-subtitle">覆盖 Agent、推理、训练优化、RAG、多模态、代码智能、生成、安全、语音、机器人、评测、数据工程和系统部署。</p>
      <div class="action-row">
        <a class="button" href={latest?.url || '/zh/archive/'}>阅读最新简报</a>
        <a class="button secondary" href="/zh/search/">搜索论文</a>
        <a class="button secondary" href="/zh/methodology/">查看方法</a>
      </div>
    </div>
  </section>

  {latest && (
    <section class="latest-panel with-topics">
      <div class="latest-main">
        <p class="section-kicker">最新一期 · {latest.meta.date}</p>
        <h2><a href={latest.url}>{displayBriefTitle(latest.meta.title)}</a></h2>
      </div>
      <aside class="topic-chips" aria-label="本期主题">
        {latestTopics.map((topic: string) => <span>{topicNames[topic] || topic}</span>)}
      </aside>
    </section>
  )}

  <section class="quick-nav">
    <a href="/zh/archive/">全部往期</a>
    <a href="/zh/topics/">专题索引</a>
    <a href="/zh/feed.xml">RSS 订阅</a>
    <a href="/zh/privacy/">隐私说明</a>
  </section>

  <section class="article-list refined-list">
    <div class="section-head clean">
      <h2>最近更新</h2>
      <a href="/zh/archive/">查看全部</a>
    </div>
    {briefs.length === 0 && <p>还没有生成内容。运行 <code>ai-brief mock-run</code> 后会出现每日简报。</p>}
    {recent.map((doc) => (
      <article class="article-card elevated-card">
        <p class="section-kicker">{doc.meta.date}</p>
        <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
      </article>
    ))}
  </section>
</BaseLayout>
