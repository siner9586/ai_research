---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadDocs, markdownToHtml } from '../../../utils/content';

export function getStaticPaths() {
  return loadDocs('zh').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const pageTitle = displayBriefTitle(doc.meta.title);
const isSources = doc.meta.page_type === 'sources';
const body = doc.meta.page_type === 'brief'
  ? doc.body.replace(/\n\*\*日期\*\*:\s*\d{4}-\d{2}-\d{2}\n\n/, '\n')
  : doc.body;
---
<BaseLayout lang="zh" title={pageTitle} description={doc.meta.summary}>
  <article class="prose">
    <div class="article-meta">
      <span>{doc.meta.date}</span>
      <span>{isSources ? '来源页' : '每日简报'}</span>
      {isSources && doc.meta.brief_page && <a class="paper-meta-link" href={doc.meta.brief_page}>返回简报</a>}
      {!isSources && doc.meta.sources_page && <a class="paper-meta-link" href={doc.meta.sources_page}>来源页</a>}
    </div>
    <Fragment set:html={markdownToHtml(body)} />
  </article>
</BaseLayout>
