---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadDocs, markdownToHtml } from '../../../utils/content';

export function getStaticPaths() {
  return loadDocs('zh').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const pageTitle = displayBriefTitle(doc.meta.title);
const body = doc.meta.page_type === 'brief'
  ? doc.body.replace(/\n\*\*日期\*\*:\s*\d{4}-\d{2}-\d{2}\n\n/, '\n')
  : doc.body;
---
<BaseLayout lang="zh" title={pageTitle} description={doc.meta.summary}>
  <article class="prose">
    <div class="article-meta">
      <span>{doc.meta.date}</span>
      <span>每日简报</span>
    </div>
    <Fragment set:html={markdownToHtml(body)} />
  </article>
</BaseLayout>
