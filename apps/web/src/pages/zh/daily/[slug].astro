---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadDocs, markdownToHtml } from '../../../utils/content';
import { getFeaturedPaperTitleItems, renderFeaturedPaperTitlesHtml } from '../../../utils/featuredTitles';

export function getStaticPaths() {
  return loadDocs('zh').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const pageTitle = displayBriefTitle(doc.meta.title);
const isSources = doc.meta.page_type === 'sources';
const sourceDate = doc.meta.actual_date || doc.meta.target_date || doc.meta.date;
const isFallback = Boolean(doc.meta.actual_date && doc.meta.target_date && doc.meta.actual_date !== doc.meta.target_date);
const body = doc.meta.page_type === 'brief'
  ? doc.body.replace(/\n\*\*日期\*\*:\s*\d{4}-\d{2}-\d{2}\n\n/, '\n')
  : doc.body;
const displayBody = body.replace(/^\s*#\s+.*\n+/, '');
const featuredTitles = !isSources ? getFeaturedPaperTitleItems(doc, 'zh', 6) : [];
const articleHtml = markdownToHtml(displayBody);
const featuredDigestHtml = !isSources && featuredTitles.length > 0
  ? renderFeaturedPaperTitlesHtml(featuredTitles, 'zh')
  : '';
---
<BaseLayout lang="zh" title={pageTitle} description={doc.meta.summary}>
  <article class:list={['brief-article', isSources && 'source-article']}>
    <header class="brief-hero">
      <span class="date-badge">{doc.meta.date}</span>
      <h1>{pageTitle}</h1>
      {doc.meta.summary && <p class="brief-summary">{doc.meta.summary}</p>}
      <div class="brief-actions">
        {isSources && doc.meta.brief_page && <a class="button" href={doc.meta.brief_page}>返回简报</a>}
        {!isSources && doc.meta.sources_page && <a class="button secondary" href={doc.meta.sources_page}>查看来源页</a>}
        <a class="button secondary" href={`/en/daily/${doc.slug}/`}>English</a>
      </div>
    </header>

    <div class="brief-meta-bar" aria-label="本期元信息">
      <span>发布 <strong>{doc.meta.date}</strong></span>
      <span>目标源日 <strong>{doc.meta.target_date || '-'}</strong></span>
      <span>实际源日 <strong>{doc.meta.actual_date || sourceDate}</strong></span>
      <span>候选 <strong>{doc.meta.candidate_count || 0}</strong></span>
      <span>重点 <strong>{doc.meta.featured_count || 0}</strong></span>
      <span>关注 <strong>{doc.meta.mentions_count || 0}</strong></span>
      {isFallback && <span class="fallback-badge">源日回退</span>}
    </div>

    {isSources ? (
      <section class="source-info-card">
        <h2>生成记录</h2>
        <p>本页保留本期入选论文、候选规模与源日期信息，用于追溯简报来源。页面仅改变展示方式，不改变入选论文、排序和数量。</p>
      </section>
    ) : (
      <Fragment>
        <p class="source-info-card">
          本期从 <strong>{sourceDate}</strong> 论文源抓取并去重 <strong>{doc.meta.candidate_count || 0}</strong> 篇候选论文，筛选 <strong>{doc.meta.featured_count || 0}</strong> 篇重点论文与 <strong>{doc.meta.mentions_count || 0}</strong> 篇补充关注。
        </p>
        {featuredDigestHtml && <Fragment set:html={featuredDigestHtml} />}
      </Fragment>
    )}

    <div class="prose">
      <Fragment set:html={articleHtml} />
    </div>
  </article>
</BaseLayout>
