---
import '../styles/global.css';
import '../styles/brief-wrap.css';
import '../styles/ui-refinements.css';
import { loadSite } from '../utils/content';

const { lang = 'en', title, description } = Astro.props;
const site = loadSite()[lang];
const otherLang = lang === 'zh' ? 'en' : 'zh';
const navLabels = lang === 'zh'
  ? {
      latest: '最新',
      archive: '归档',
      topics: '标签',
      search: '搜索',
      sources: '来源说明',
      wechat: '公众号',
      other: 'English',
      footerTitle: 'AI 研究简报',
      footerNote: '本项目基于 arXiv 公开元数据与公开信号自动生成，仅用于研究跟踪与信息筛选，不替代原文阅读。',
      repo: 'GitHub 仓库',
      rss: 'RSS',
      privacy: '隐私',
      closeWechat: '关闭公众号二维码',
    }
  : {
      latest: 'Latest',
      archive: 'Archive',
      topics: 'Topics',
      search: 'Search',
      sources: 'Sources',
      wechat: 'WeChat',
      other: '中文',
      footerTitle: 'AI Research Brief',
      footerNote: 'This project generates source-first AI research briefs from public arXiv metadata and public signals. It is intended for research tracking and discovery, not as a replacement for reading the original papers.',
      repo: 'GitHub',
      rss: 'RSS',
      privacy: 'Privacy',
      closeWechat: 'Close WeChat QR code',
    };
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | ${site.name}` : site.name}</title>
    <meta name="description" content={description || site.tagline} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" href={`/${lang}/feed.xml`} />
  </head>
  <body data-lang={lang}>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={`/${lang}/`} aria-label={site.name}>
          <span class="brand-mark">AI</span>
          <span>{site.name}</span>
        </a>
        <div class="nav-links">
          <a href={`/${lang}/`}>{navLabels.latest}</a>
          <a href={`/${lang}/archive/`}>{navLabels.archive}</a>
          <a href={`/${lang}/topics/`}>{navLabels.topics}</a>
          <a href={`/${lang}/search/`}>{navLabels.search}</a>
          <a href={`/${lang}/methodology/`}>{navLabels.sources}</a>
          <span class="nav-wechat">
            <button class="nav-wechat-trigger" type="button" data-wechat-open aria-haspopup="dialog" aria-expanded="false" aria-controls="wechat-popover">
              {navLabels.wechat}
            </button>
            <div id="wechat-popover" class="wechat-popover" role="dialog" aria-labelledby="wechat-title" data-wechat-popover hidden>
              <button class="wechat-close" type="button" data-wechat-close aria-label={navLabels.closeWechat}>×</button>
              <p class="wechat-eyebrow">扫码关注公众号：</p>
              <p id="wechat-title" class="wechat-title">灵感与观点交流</p>
              <img src="/wechat-qr.jpeg" alt="公众号二维码" width="260" height="260" loading="lazy" />
            </div>
          </span>
          <a href={`/${otherLang}/`}>{navLabels.other}</a>
        </div>
      </nav>
    </header>
    <main class="page">
      <slot />
    </main>
    <div class="footer-shell">
      <footer class="footer">
        <div>
          <strong>{navLabels.footerTitle}</strong>
          <p>{navLabels.footerNote}</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/siner9586/ai_research" target="_blank" rel="noopener noreferrer">{navLabels.repo}</a>
          <a href={`/${lang}/feed.xml`}>{navLabels.rss}</a>
          <a href={`/${lang}/privacy/`}>{navLabels.privacy}</a>
        </div>
      </footer>
    </div>
    <script is:inline>
      const popover = document.querySelector('[data-wechat-popover]');
      const openButton = document.querySelector('[data-wechat-open]');
      const closeButton = document.querySelector('[data-wechat-close]');

      const openWechat = () => {
        popover?.removeAttribute('hidden');
        openButton?.setAttribute('aria-expanded', 'true');
        closeButton?.focus();
      };

      const closeWechat = () => {
        popover?.setAttribute('hidden', '');
        openButton?.setAttribute('aria-expanded', 'false');
        openButton?.focus();
      };

      openButton?.addEventListener('click', () => {
        if (popover?.hasAttribute('hidden')) {
          openWechat();
        } else {
          closeWechat();
        }
      });
      closeButton?.addEventListener('click', closeWechat);
      document.addEventListener('click', (event) => {
        if (popover?.hasAttribute('hidden')) return;
        if (event.target instanceof Node && !popover?.contains(event.target) && !openButton?.contains(event.target)) {
          closeWechat();
        }
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !popover?.hasAttribute('hidden')) closeWechat();
      });
    </script>
  </body>
</html>
