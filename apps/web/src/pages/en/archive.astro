---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadBriefs } from '../../utils/content';
const briefs = loadBriefs('en');
---
<BaseLayout lang="en" title="Archive">
  <h1>Archive</h1>
  <section class="article-list">
    {briefs.map((doc) => (
      <article class="article-card">
        <h2><a href={doc.url}>{displayBriefTitle(doc.meta.title)}</a></h2>
        <div class="article-meta"><span>{doc.meta.date}</span></div>
      </article>
    ))}
  </section>
</BaseLayout>
