---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { displayBriefTitle, loadDocs, markdownToHtml } from '../../../utils/content';

export function getStaticPaths() {
  return loadDocs('en').map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const pageTitle = displayBriefTitle(doc.meta.title);
const isSources = doc.meta.page_type === 'sources';
const selectedCount = (doc.meta.featured_count || 0) + (doc.meta.mentions_count || 0);
const sourceDate = doc.meta.actual_date || doc.meta.target_date || doc.meta.date;
const body = doc.meta.page_type === 'brief'
  ? doc.body.replace(/\n\*\*Date\*\*:\s*\d{4}-\d{2}-\d{2}\n\n/, '\n')
  : doc.body;
---
<BaseLayout lang="en" title={pageTitle} description={doc.meta.summary}>
  <article class="prose">
    <div class="article-meta issue-meta-line">
      <span>{doc.meta.date}</span>
      <span>{isSources ? 'source page' : 'daily brief'}</span>
      <span>{doc.meta.candidate_count || 0} candidates</span>
      <span>{doc.meta.featured_count || 0} featured</span>
      <span>{doc.meta.mentions_count || 0} additional</span>
      {isSources && doc.meta.brief_page && <a class="paper-meta-link" href={doc.meta.brief_page}>Back to brief</a>}
      {!isSources && doc.meta.sources_page && <a class="paper-meta-link" href={doc.meta.sources_page}>Source page</a>}
    </div>
    {!isSources && (
      <p class="candidate-note">
        This issue fetched and deduplicated <strong>{doc.meta.candidate_count || 0}</strong> candidate papers from the <strong>{sourceDate}</strong> source date, then selected <strong>{doc.meta.featured_count || 0}</strong> featured papers and <strong>{doc.meta.mentions_count || 0}</strong> additional mentions.
      </p>
    )}
    <Fragment set:html={markdownToHtml(body)} />
  </article>
</BaseLayout>

<style>
  .issue-meta-line { display: flex; flex-wrap: wrap; gap: 8px 12px; align-items: center; }
  .candidate-note { margin: 14px 0 22px; padding: 10px 12px; border: 1px solid var(--border); border-radius: 14px; background: var(--surface-soft); color: var(--muted); font-size: 0.94rem; }
  .candidate-note strong { color: var(--text); }
</style>
