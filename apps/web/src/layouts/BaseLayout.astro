---
import '../styles/global.css';
import { loadSite } from '../utils/content';

const { lang = 'en', title, description } = Astro.props;
const site = loadSite()[lang];
const otherLang = lang === 'zh' ? 'en' : 'zh';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | ${site.name}` : site.name}</title>
    <meta name="description" content={description || site.tagline} />
    <link rel="alternate" type="application/rss+xml" href={`/${lang}/feed.xml`} />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav">
        <a class="brand" href={`/${lang}/`}>{site.name}</a>
        <div class="nav-links">
          <a href={`/${lang}/archive/`}>{lang === 'zh' ? '归档' : 'Archive'}</a>
          <a href={`/${lang}/topics/`}>{lang === 'zh' ? '专题' : 'Topics'}</a>
          <a href={`/${lang}/search/`}>{lang === 'zh' ? '搜索' : 'Search'}</a>
          <a href={`/${lang}/methodology/`}>{lang === 'zh' ? '方法' : 'Method'}</a>
          <button class="nav-wechat-trigger" type="button" data-wechat-open aria-haspopup="dialog" aria-controls="wechat-popover">
            公众号
          </button>
          <a href={`/${otherLang}/`}>{otherLang.toUpperCase()}</a>
        </div>
      </nav>
    </header>
    <div class="wechat-overlay" data-wechat-overlay hidden>
      <div id="wechat-popover" class="wechat-popover" role="dialog" aria-modal="true" aria-labelledby="wechat-title">
        <button class="wechat-close" type="button" data-wechat-close aria-label={lang === 'zh' ? '关闭公众号二维码' : 'Close WeChat QR code'}>×</button>
        <p class="wechat-eyebrow">扫码关注公众号：</p>
        <p id="wechat-title" class="wechat-title">灵感与观点交流</p>
        <img src="/wechat-qr.jpeg" alt="公众号二维码" width="260" height="260" loading="lazy" />
      </div>
    </div>
    <main class="page">
      <slot />
    </main>
    <footer class="footer">
      <span>{site.tagline}</span>
      <span>{lang === 'zh' ? '内容由本仓库流水线生成，原论文链接为事实来源。' : 'Generated by the local pipeline; original papers remain the source of record.'}</span>
    </footer>
    <script is:inline>
      const overlay = document.querySelector('[data-wechat-overlay]');
      const openButton = document.querySelector('[data-wechat-open]');
      const closeButton = document.querySelector('[data-wechat-close]');

      const openWechat = () => {
        overlay?.removeAttribute('hidden');
        document.body.classList.add('modal-open');
        closeButton?.focus();
      };

      const closeWechat = () => {
        overlay?.setAttribute('hidden', '');
        document.body.classList.remove('modal-open');
        openButton?.focus();
      };

      openButton?.addEventListener('click', openWechat);
      closeButton?.addEventListener('click', closeWechat);
      overlay?.addEventListener('click', (event) => {
        if (event.target === overlay) closeWechat();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !overlay?.hasAttribute('hidden')) closeWechat();
      });
    </script>
  </body>
</html>
