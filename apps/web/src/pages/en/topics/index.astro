---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { loadTopics, topicCounts } from '../../../utils/content';
const topics = loadTopics();
const counts = topicCounts('en');
---
<BaseLayout lang="en" title="Topics">
  <section class="topic-hero">
    <div>
      <h1 class="page-title">Topics</h1>
      <p class="page-subtitle">Browse generated briefs through existing topics/tags. Counts come from published briefs without adding classification logic.</p>
    </div>
    <aside class="info-card">
      <h2>Topic Index</h2>
      <p>Quick paths into agents, RAG, evaluation, multimodal models, systems, and other recurring research signals.</p>
    </aside>
  </section>
  <section class="topic-grid">
    {topics.map((topic) => (
      <a class="topic-row" href={`/en/topics/${topic.slug}/`}>
        <strong>{topic.en}</strong>
        <p>{counts[topic.slug] || 0} related briefs</p>
      </a>
    ))}
  </section>
</BaseLayout>
